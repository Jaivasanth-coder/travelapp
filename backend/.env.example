# ============================================================
#  ProShop — Environment Configuration
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to git — add it to .gitignore!
# ============================================================

# ── ENVIRONMENT ──────────────────────────────────────────────
# Set to "development" locally, "production" on Render/Railway
NODE_ENV=development


# ── DATABASE URLs ─────────────────────────────────────────────
#
# LOCAL (PostgreSQL running on your machine)
# Install locally: https://www.postgresql.org/download/
# After install, create DB:
#   psql -U postgres
#   CREATE DATABASE proshop_local;
#   \q
# Then run: psql -U postgres -d proshop_local -f proshop_postgres.sql
#
DATABASE_URL_LOCAL=postgresql://postgres:yourpassword@127.0.0.1:5432/proshop_local

#
# PRODUCTION (Render PostgreSQL — free tier available)
# Steps to get this URL:
#   1. Go to https://dashboard.render.com
#   2. Click "New +" → "PostgreSQL"
#   3. Name it "proshop-db", choose Free plan
#   4. After creation, copy "External Database URL"
#   5. Paste it below
#
DATABASE_URL_PROD=postgresql://proshop_user:XXXXXXXXXXXX@dpg-XXXXXXXX.oregon-postgres.render.com/proshop_db

#
# ACTIVE URL — which one your app uses right now
# Locally: set to DATABASE_URL_LOCAL
# On Render: Render auto-sets DATABASE_URL from its own DB, so
#            your backend code should just read process.env.DATABASE_URL
#
DATABASE_URL=postgresql://postgres:yourpassword@127.0.0.1:5432/proshop_local


# ── SERVER ────────────────────────────────────────────────────
PORT=5000
# On Render, PORT is auto-set — don't hardcode it there.


# ── SECURITY ──────────────────────────────────────────────────
# Generate a strong random secret:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace_this_with_a_long_random_string_min_32_chars
SESSION_SECRET=replace_this_with_another_long_random_string

# Admin credentials (these bootstrap the admins table in schema)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123   # ← CHANGE THIS before going live!


# ── UPI / PAYMENT ─────────────────────────────────────────────
UPI_ID=9884856840@ybl
UPI_NAME=Jayasri


# ── DELIVERY CONFIG ───────────────────────────────────────────
VALID_PINCODE=600063
# Comma-separated list of served apartments
SERVED_APARTMENTS=Isha Anandam,Isha Shubham,Isha Santhosham,TVS Green Hills Apartment,SSM Nagar


# ── OTP (optional SMS gateway) ────────────────────────────────
# If using Fast2SMS or MSG91, add API key here
# Leave blank to use dev mode (OTP printed in response)
SMS_API_KEY=
SMS_SENDER_ID=PROSHP


# ============================================================
#  HOW YOUR BACKEND SHOULD READ DATABASE_URL
#  (Node.js / Express + pg example)
# ============================================================
#
#  const { Pool } = require('pg');
#  const pool = new Pool({
#    connectionString: process.env.DATABASE_URL,
#    ssl: process.env.NODE_ENV === 'production'
#         ? { rejectUnauthorized: false }   // required for Render
#         : false
#  });
#
# ============================================================
